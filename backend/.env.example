# ──────────────────────────────────────────
# Polymarket Platform — Environment Config
# ──────────────────────────────────────────
# Copy this file to .env and fill in your values.

# Application
DEBUG=false

# Server
HOST=0.0.0.0
PORT=8000

# Database (PostgreSQL + TimescaleDB)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/polymarket

# Redis
REDIS_URL=redis://localhost:6379/0

# ── Polymarket US API Keys ──
# Get these from: polymarket.us/developer
POLYMARKET_KEY_ID=
POLYMARKET_SECRET_KEY=

# ── Polymarket International (Crypto) ──
# Private key for Polygon wallet (hex, without 0x prefix)
POLY_INTL_PRIVATE_KEY=
# Funder address (optional, for gasless transactions)
POLY_INTL_FUNDER_ADDRESS=

# ── Kalshi API ──
# Get key from: kalshi.com → Account & Security → API Keys
KALSHI_API_KEY_ID=
# Path to the RSA private key .key file downloaded from Kalshi
KALSHI_PRIVATE_KEY_PATH=

# ── Falcon API (Polymarket Analytics) ──
# Get token from: api.polymarketanalytics.com/sign-up
FALCON_API_TOKEN=

# Risk Management
MAX_POSITION_SIZE=1000
MAX_TOTAL_EXPOSURE=10000.0
MAX_DAILY_LOSS=500.0
BUYING_POWER_RESERVE_PCT=0.20
MAX_CONCENTRATION_PCT=0.25

# Frontend CORS
CORS_ORIGINS=["http://localhost:3000"]
